ire:key":"1XgJvLIadKD23Xp007t5.data.email.Filament\\Forms\\Components\\TextInput"},[[17,225]],[[17,226]],["DIV",{"data-field-wrapper":"","class":"fi-fo-field-wrp"},[[17,227]],[[17,228]],["DIV",{"class":"grid gap-y-2"},[[17,229]],[[17,230]],[[17,245]],[[17,246]],[[17,247]],[[17,248]],["DIV",{"class":"grid auto-cols-fr gap-y-2"},[[17,249]],["DIV",{"class":"fi-input-wrp flex rounded-lg shadow-sm ring-1 transition duration-75 bg-white dark:bg-white/5 [&:not(:has(.fi-ac-action:focus))]:focus-within:ring-2 ring-gray-950/10 dark:ring-white/20 [&:not(:has(.fi-ac-action:focus))]:focus-within:ring-primary-600 dark:[&:not(:has(.fi-ac-action:focus))]:focus-within:ring-primary-500 fi-fo-text-input overflow-hidden"},[[17,250]],[[17,251]],["DIV",{"class":"fi-input-wrp-input min-w-0 flex-1"},[[17,252]],["INPUT",{"__playwright_value_":"admin@kise.ac.ke","__playwright_target__":"call@14","class":"fi-input block w-full border-none py-1.5 text-base text-gray-950 transition duration-75 placeholder:text-gray-400 focus:ring-0 disabled:text-gray-500 disabled:[-webkit-text-fill-color:theme(colors.gray.500)] disabled:placeholder:[-webkit-text-fill-color:theme(colors.gray.400)] dark:text-white dark:placeholder:text-gray-500 dark:disabled:text-gray-400 dark:disabled:[-webkit-text-fill-color:theme(colors.gray.400)] dark:disabled:placeholder:[-webkit-text-fill-color:theme(colors.gray.500)] sm:text-sm sm:leading-6 bg-white/0 ps-3 pe-3","autocomplete":"on","autofocus":"autofocus","id":"data.email","required":"required","type":"email","wire:model":"data.email","tabindex":"1","readonly":"","style":""}],[[17,254]]],[[17,256]],[[17,257]]],[[17,259]],[[17,260]],[[17,261]],[[17,262]]],[[17,264]],[[17,265]]],[[17,267]]],[[17,269]],[[17,270]]],[[17,272]],["DIV",{"style":"--col-span-default: span 1 / span 1;","class":"col-[--col-span-default]","wire:key":"1XgJvLIadKD23Xp007t5.data.password.Filament\\Forms\\Components\\TextInput"},[[17,273]],[[17,274]],["DIV",{"data-field-wrapper":"","class":"fi-fo-field-wr